@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/annotorious/annotorious/dist/annotorious.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/lib/annotorious/annotorious/dist/annotorious.min.css" />
    </environment>
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card mb-4">
            <div class="card-body">
                <div class="d-flex align-items-start">
                    <div class="flex-grow-1">
                        <textarea class="form-control" rows="3" placeholder="What's on your mind?"
                                  data-bind="value: newPostContent"></textarea>
                    </div>
                </div>
                <div class="mt-2 text-end">
                    <button class="btn btn-primary" data-bind="click: createPost, enable: newPostContent()">
                        <i class="bi bi-send"></i> Post
                    </button>
                </div>
            </div>
        </div>

        <div data-bind="visible: loading" class="text-center py-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading…</span>
            </div>
        </div>

        <div data-bind="foreach: feedItems, visible: !loading()">
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div data-bind="if: authorProfileImage">
                            <img data-bind="attr: { src: '/uploads/' + authorProfileImage() }" class="rounded-circle me-2" width="40" height="40" alt="" />
                        </div>
                        <div data-bind="ifnot: authorProfileImage">
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2" style="width:40px;height:40px;">
                                <i class="bi bi-person"></i>
                            </div>
                        </div>
                        <div>
                            <a data-bind="text: authorName, attr: { href: '/Profile/View/' + authorPersonId() }" class="fw-bold text-decoration-none"></a>
                            <div class="text-muted small" data-bind="text: timeAgo"></div>
                        </div>
                    </div>

                    <!-- ko if: type() === 'post' -->
                    <p class="card-text" data-bind="text: content"></p>
                    <!-- /ko -->

                    <!-- ko if: type() === 'photo' -->
                    <p class="card-text fw-semibold" data-bind="text: title"></p>
                    <a href="#" data-bind="click: function(data, event) { $root.openLightbox($data); return false; }">
                        <img data-bind="attr: { src: '/uploads/' + filePath() }" class="img-fluid rounded" alt=""
                             style="cursor:pointer; max-height:400px; object-fit:cover;" />
                    </a>
                    <!-- /ko -->

                    <!-- ko if: type() === 'video' -->
                    <p class="card-text fw-semibold" data-bind="text: title"></p>
                    <!-- ko if: thumbnailPath -->
                    <a href="#" class="d-block position-relative" style="display:inline-block;"
                       data-bind="click: function(data, event) { $root.openVideoLightbox($data); return false; }">
                        <img data-bind="attr: { src: '/uploads/' + thumbnailPath() }" class="img-fluid rounded" alt=""
                             style="cursor:pointer; max-height:400px; max-width:100%; object-fit:cover;" />
                        <div class="position-absolute top-50 start-50 translate-middle"
                             style="pointer-events:none; background:rgba(0,0,0,0.5); border-radius:50%; width:52px; height:52px; display:flex; align-items:center; justify-content:center;">
                            <i class="bi bi-play-fill text-white" style="font-size:1.6rem; margin-left:4px;"></i>
                        </div>
                    </a>
                    <!-- /ko -->
                    <!-- /ko -->
                </div>
            </div>
        </div>

        <div data-bind="visible: !loading() && feedItems().length === 0" class="text-center text-muted py-4">
            <i class="bi bi-chat-text" style="font-size: 3rem;"></i>
            <p class="mt-2">No updates yet. Be the first to post!</p>
        </div>

        <!-- Infinite scroll sentinel (item 2) – load more button still shown as fallback -->
        <div id="feedSentinel" class="py-2"></div>
        <div data-bind="visible: hasMore && !loading()" class="text-center mb-4">
            <button class="btn btn-outline-primary" data-bind="click: loadMore">Load More</button>
        </div>
    </div>
</div>

<!-- Photo lightbox (item 12) -->
<div class="modal fade" id="homeLightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-dark">
            <div class="modal-header border-0 pb-0">
                <span class="text-white fw-semibold" data-bind="text: lightboxTitle, visible: lightboxTitle()"></span>
                <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-2">
                <div class="form-check mb-2" data-bind="visible: lightboxHasAnnotations">
                    <input class="form-check-input" type="checkbox" id="homeLightboxShowAnnotations" data-bind="checked: lightboxShowAnnotations" />
                    <label class="form-check-label text-white small" for="homeLightboxShowAnnotations">Show annotations</label>
                </div>
                <div id="homeLightboxImageArea" class="text-center">
                    <img id="homeLightboxImage" data-bind="attr: { src: lightboxUrl }" class="img-fluid rounded" style="max-height:85vh;" alt="" />
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Video lightbox -->
<div class="modal fade" id="homeVideoLightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-fullscreen-lg-down">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header border-secondary py-2">
                <span class="fw-semibold" data-bind="text: videoLightboxTitle"></span>
                <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-2 d-flex justify-content-center align-items-center bg-black">
                <video id="homeVideoLightboxPlayer" controls playsinline class="w-100 rounded" style="max-height:85vh;"
                       data-bind="attr: { src: videoLightboxUrl }"></video>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <environment include="Development">
        <script src="~/lib/annotorious/annotorious/dist/annotorious.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/annotorious/annotorious/dist/annotorious.min.js"></script>
    </environment>
    <script src="~/js/home.js" asp-append-version="true"></script>
}
