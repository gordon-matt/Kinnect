@inject Kinnect.Infrastructure.IAuthProviderService AuthProviderService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kinnect</title>

    <environment include="Development">
        <link rel="stylesheet" href="~/lib/bootswatch/dist/flatly/bootstrap.css" />
        <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="~/lib/egalink-toasty.js/dist/toasty.css" />
        <link rel="stylesheet" href="~/lib/yaireo/tagify/dist/tagify.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/lib/bootswatch/dist/flatly/bootstrap.min.css" />
        <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css">
        <link rel="stylesheet" href="~/lib/egalink-toasty.js/dist/toasty.min.css" />
        <link rel="stylesheet" href="~/lib/yaireo/tagify/dist/tagify.min.css" />
    </environment>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@ViewData["BodyClass"]">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="/img/Logo.png" alt="Kinnect" height="50" />
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house"></i> Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="FamilyTree" asp-action="Index">
                                    <i class="bi bi-diagram-3"></i> Family Tree
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Map" asp-action="Index">
                                    <i class="bi bi-geo-alt"></i> Map
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-person-circle"></i> My Profile
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Chat" asp-action="Index">
                                    <i class="bi bi-chat-dots"></i> Messages
                                </a>
                            </li>
                            @if (User.IsInRole("Administrator"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-shield-lock"></i> Admin
                                    </a>
                                    <ul class="dropdown-menu">
                                        @if (!Constants.UseKeyCloak)
                                        {
                                            <li>
                                                <a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                                    <i class="bi bi-people"></i> Users
                                                </a>
                                            </li>
                                        }
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="PersonBackups">
                                                <i class="bi bi-database-down"></i> Person backups
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="/sejil" target="_blank">
                                                <i class="bi bi-file-earmark-text"></i> Log
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="/hangfire" target="_blank">
                                                <i class="bi bi-clock"></i> Scheduled Tasks
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                        </ul>
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <span class="nav-link text-light">
                                    <i class="bi bi-person"></i> @User.Identity?.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form method="post" action="/auth/logout">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="nav-link btn btn-link text-light">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link" href="/auth/login">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="@(ViewData["FullWidth"] != null ? "" : "container-fluid mt-3")">
        <main role="main" class="@(ViewData["FullWidth"] != null ? "" : "pb-3")">
            @RenderBody()
        </main>
    </div>

    @if (ViewData["FullWidth"] == null)
    {
        <footer class="border-top footer text-muted">
            <div class="container-fluid">
                &copy; @DateTime.Now.Year - Kinnect
            </div>
        </footer>
    }

    <environment include="Development">
        <script src="~/lib/jquery/dist/jquery.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
        <script src="~/lib/knockout/build/output/knockout-latest.js"></script>
        <script src="~/lib/yaireo/tagify/dist/tagify.js"></script>
        <script src="~/lib/egalink-toasty.js/dist/toasty.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/lib/knockout/build/output/knockout-latest.min.js"></script>
        <script src="~/lib/yaireo/tagify/dist/tagify.min.js"></script>
        <script src="~/lib/egalink-toasty.js/dist/toasty.min.js"></script>
    </environment>

    <script type="text/javascript">
        const toast = new Toasty({
            enableSounds: true,
            sounds: {
                info: "/lib/egalink-toasty.js/dist/sounds/info/1.mp3",
                success: "/lib/egalink-toasty.js/dist/sounds/success/1.mp3",
                warning: "/lib/egalink-toasty.js/dist/sounds/warning/1.mp3",
                error: "/lib/egalink-toasty.js/dist/sounds/error/1.mp3",
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
