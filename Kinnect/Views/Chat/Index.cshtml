@{
    ViewData["Title"] = "Messages";
    ViewData["FullWidth"] = true;
    ViewData["BodyClass"] = "chat-page";
    string? initialPrivateUserId = ViewData["InitialPrivateUserId"] as string;
    string? initialPrivateUserName = ViewData["InitialPrivateUserName"] as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
}

<div class="alert alert-warning alert-dismissible d-none" id="chat-error-alert" role="alert">
    <span data-bind="text: serverInfoMessage"></span>
    <button type="button" class="btn-close" aria-label="Close"></button>
</div>

<!-- Loading spinner -->
<div class="d-flex flex-column justify-content-center align-items-center chat-loading d-none">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading&hellip;</span>
    </div>
</div>

<!-- Chat app shell -->
<div class="chat-app">

    <!-- Sidebar: rooms & direct messages -->
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <span class="fw-semibold">Rooms</span>
            <div class="d-flex gap-2 align-items-center">
                <a role="button" title="New room" data-bs-toggle="modal" data-bs-target="#create-room-modal">
                    <i class="bi bi-plus-circle"></i>
                </a>
                <a role="button" title="Toggle users" id="expand-users-list">
                    <i class="bi bi-people"></i>
                </a>
            </div>
        </div>

        <ul class="chat-rooms-list list-unstyled mb-0" data-bind="foreach: chatRooms">
            <li data-bind="css: { active: $root.activeRoomId() === id() }">
                <a href="#" data-bind="text: name, click: $root.joinRoom.bind($data)"></a>
            </li>
        </ul>

        <!-- Private conversations -->
        <div class="chat-sidebar-section-header" data-bind="visible: privateConversations().length > 0">
            Direct Messages
        </div>
        <ul class="chat-rooms-list list-unstyled mb-0" data-bind="foreach: privateConversations">
            <li data-bind="css: { active: $root.activePrivateUserId() === userId() }">
                <a href="#" data-bind="text: fullName, click: $root.openPrivateChat.bind($data)"></a>
            </li>
        </ul>

        <div class="chat-sidebar-profile">
            <div class="d-flex align-items-center flex-grow-1 overflow-hidden">
                <div class="chat-avatar me-2 text-uppercase flex-shrink-0" data-bind="text: myProfile() ? myProfile().fullName()[0] : ''"></div>
                <span class="text-truncate small" data-bind="text: myProfile() ? myProfile().fullName() : ''"></span>
            </div>
            <a href="/Profile" title="My Profile" class="text-muted ms-2 flex-shrink-0">
                <i class="bi bi-person-circle"></i>
            </a>
        </div>
    </div>

    <!-- Main chat content -->
    <div class="chat-main">
        <!-- No conversation selected -->
        <div class="chat-empty" data-bind="visible: activeRoomId() == null && activePrivateUserId() == null">
            <i class="bi bi-chat-dots" style="font-size:3rem;opacity:.25;"></i>
            <p class="mt-2 text-muted">Select a room or start a private conversation.</p>
        </div>

        <!-- Room chat panel -->
        <div class="chat-panel" data-bind="visible: activeRoomId() != null">
            <div class="chat-panel-header">
                <i class="bi bi-hash me-1 text-muted small"></i>
                <span data-bind="text: activeRoomName()"></span>

                <!-- ko if: canManageActiveRoom() -->
                <div class="ms-auto d-flex gap-1">
                    <button type="button" class="btn btn-link btn-sm text-secondary p-0" data-bs-toggle="modal" data-bs-target="#rename-room-modal" title="Rename room">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button type="button" class="btn btn-link btn-sm text-secondary p-0" data-bs-toggle="modal" data-bs-target="#remove-room-modal" title="Delete room">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                <!-- /ko -->
            </div>
            <div class="chat-messages" id="chat-messages-room">
                <div class="chat-no-messages text-muted small" data-bind="visible: chatMessages().length === 0">No messages yet.</div>
                <ul class="list-unstyled mb-0" data-bind="foreach: chatMessages">
                    <li class="chat-message-item" data-bind="css: { ismine: isMine() }">
                        <div class="chat-avatar text-uppercase flex-shrink-0" data-bind="text: fromFullName()[0]"></div>
                        <div class="chat-message-body">
                            <div class="chat-message-meta">
                                <span class="fw-semibold small" data-bind="text: fromFullName"></span>
                                <span class="text-muted chat-timestamp ms-2" data-bind="text: timestampDisplay"></span>
                            </div>
                            <div class="chat-message-content" data-bind="text: content"></div>
                        </div>
                        <div class="chat-message-actions" data-bind="visible: isMine()">
                            <button type="button" class="btn btn-link btn-sm p-0 text-muted"
                                    data-bs-toggle="modal" data-bs-target="#remove-message-modal"
                                    data-bind="attr: { 'data-message-id': id }">
                                <i class="bi bi-trash" style="font-size:.75rem;"></i>
                            </button>
                        </div>
                    </li>
                </ul>
            </div>
            <div class="chat-input-area">
                @* Use 'input' not afterkeydown — KO updates after the browser applies the character (avoids one-char lag, esp. Firefox). *@
                <input id="chat-message-input" type="text" class="form-control" maxlength="500"
                       placeholder="Type a message&hellip;"
                       data-bind="value: messageText, valueUpdate: 'input', event: { keydown: onEnterKey }, disable: !canPostToActiveRoom()" />
                <button class="btn btn-primary ms-2 flex-shrink-0" type="button" data-bind="click: sendRoomMessage, disable: !canPostToActiveRoom()">
                    <i class="bi bi-send"></i>
                </button>
            </div>
        </div>

        <!-- Private chat panel -->
        <div class="chat-panel" data-bind="visible: activePrivateUserId() != null">
            <div class="chat-panel-header">
                <i class="bi bi-lock me-1 text-muted small"></i>
                <span data-bind="text: activePrivateUserName()"></span>
            </div>
            <div class="chat-messages" id="chat-messages-private">
                <div class="chat-no-messages text-muted small" data-bind="visible: privateMessages().length === 0">No messages yet.</div>
                <ul class="list-unstyled mb-0" data-bind="foreach: privateMessages">
                    <li class="chat-message-item" data-bind="css: { ismine: isMine() }">
                        <div class="chat-avatar text-uppercase flex-shrink-0" data-bind="text: fromFullName()[0]"></div>
                        <div class="chat-message-body">
                            <div class="chat-message-meta">
                                <span class="fw-semibold small" data-bind="text: fromFullName"></span>
                                <span class="text-muted chat-timestamp ms-2" data-bind="text: timestampDisplay"></span>
                            </div>
                            <div class="chat-message-content" data-bind="text: content"></div>
                        </div>
                    </li>
                </ul>
            </div>
            <div class="chat-input-area">
                <input id="private-message-input" type="text" class="form-control" maxlength="500"
                       placeholder="Type a message&hellip;"
                       data-bind="value: privateMessageText, valueUpdate: 'input', event: { keydown: onPrivateEnterKey }" />
                <button class="btn btn-primary ms-2 flex-shrink-0" type="button" data-bind="click: sendPrivateMessage">
                    <i class="bi bi-send"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Online users panel -->
    <div class="chat-users-panel" id="chat-users-panel">
        <div class="chat-sidebar-header">
            <span class="fw-semibold">Online (<span data-bind="text: onlineUsers().length"></span>)</span>
        </div>
        <ul class="list-unstyled px-2 mb-0" data-bind="foreach: onlineUsers">
            <li class="py-1 d-flex align-items-center gap-2 chat-user-row position-relative"
                data-bind="click: $root.selectOnlineUser">
                <div class="chat-avatar text-uppercase flex-shrink-0" data-bind="text: fullName()[0]"></div>
                <span class="small text-truncate flex-grow-1" data-bind="text: fullName"></span>
                <i class="bi bi-three-dots-vertical chat-user-row-dots text-muted"></i>

                <!-- ko if: $root.selectedOnlineUser() === $data -->
                <div class="chat-user-menu dropdown-menu show shadow-sm"
                     data-bind="click: function(d,e){ e.stopPropagation(); }">
                    <!-- ko if: personId() -->
                    <a class="dropdown-item small py-1"
                       data-bind="attr: { href: '/Profile/View/' + personId() }, click: $root.openOnlineUserProfile">
                        <i class="bi bi-person me-1"></i>View Profile
                    </a>
                    <!-- /ko -->
                    <button type="button" class="dropdown-item small py-1"
                            data-bind="click: $root.startPrivateChatWithUser">
                        <i class="bi bi-chat-dots me-1"></i>Send Message
                    </button>
                </div>
                <!-- /ko -->
            </li>
        </ul>
    </div>
</div>

<!-- Create room modal -->
<div class="modal fade" id="create-room-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Create Room</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" class="form-control form-control-sm" id="new-room-name" maxlength="100" placeholder="Room name&hellip;" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" data-bs-dismiss="modal" data-bind="click: createRoom">Create</button>
            </div>
        </div>
    </div>
</div>

<!-- Rename room modal -->
<div class="modal fade" id="rename-room-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Rename Room</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" class="form-control form-control-sm" id="rename-room-input" maxlength="100" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" data-bs-dismiss="modal" data-bind="click: renameRoom">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete room modal -->
<div class="modal fade" id="remove-room-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Delete Room</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Delete <strong data-bind="text: activeRoomName"></strong>? This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-danger" data-bs-dismiss="modal" data-bind="click: deleteRoom">Delete</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete message modal -->
<div class="modal fade" id="remove-message-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Delete Message</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Delete this message?</p>
                <input type="hidden" id="delete-message-id" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-danger" data-bs-dismiss="modal" data-bind="click: deleteMessage">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const chatInitialPrivateUserId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(initialPrivateUserId));
        const chatInitialPrivateUserName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(initialPrivateUserName));
    </script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
