@{
    ViewData["Title"] = "Family Tree";
    ViewData["FullWidth"] = true;
    ViewData["BodyClass"] = "family-tree-page";
    bool isAdmin = (bool)(ViewData["IsAdmin"] ?? false);
    int? myPersonId = ViewData["MyPersonId"] as int?;
}

<div class="family-tree-page-frame">
    <div class="family-tree-toolbar" role="toolbar" aria-label="Family tree actions">
        <div class="family-tree-toolbar-left">
            <button id="TogglePeoplePane"
                    type="button"
                    class="btn btn-sm btn-outline-secondary btn-toggle-people"
                    aria-expanded="false"
                    aria-controls="FamilyTreeSidebar"
                    title="Toggle people pane">
                <i class="bi bi-list" aria-hidden="true"></i>
                <span>People</span>
            </button>
            <button id="FindMeButton"
                    type="button"
                    class="btn btn-sm btn-outline-secondary btn-find-me d-none"
                    title="Center on your profile person">
                <i class="bi bi-person-circle" aria-hidden="true"></i>
                <span>Find Me</span>
            </button>
        </div>
        <a href="/api/gedcom/export"
           class="btn btn-sm btn-outline-secondary btn-export-gedcom"
           title="Download your tree as a GEDCOM file"
           download>
            <i class="bi bi-download" aria-hidden="true"></i>
            <span>Export</span>
        </a>
    </div>
    <div id="FamilyTreeBody" class="family-tree-body sidebar-collapsed">
        <aside id="FamilyTreeSidebar" class="family-tree-sidebar" aria-label="People list">
            <div class="sidebar-header">People</div>
            <div id="SidebarPersonList" class="sidebar-person-list"></div>
        </aside>
        <div id="FamilyChart" class="f3"></div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/lib/family-chart/dist/styles/family-chart.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/family-tree.css" asp-append-version="true" />
}

@section Scripts {
    <environment include="Development">
        <script src="~/lib/d3/dist/d3.js"></script>
        <script src="~/lib/family-chart/dist/family-chart.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/d3/dist/d3.min.js"></script>
        <script src="~/lib/family-chart/dist/family-chart.js"></script>
    </environment>
    <script>
        const isAdmin = @(isAdmin ? "true" : "false");
        const myPersonId = @(myPersonId.HasValue ? myPersonId.Value.ToString() : "null");
    </script>
    <script src="~/js/family-tree.js" asp-append-version="true"></script>
}
