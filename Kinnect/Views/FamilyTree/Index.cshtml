@{
    ViewData["Title"] = "Family Tree";
    ViewData["FullWidth"] = true;
    ViewData["BodyClass"] = "family-tree-page";
    bool isAdmin = (bool)(ViewData["IsAdmin"] ?? false);
    int? myPersonId = ViewData["MyPersonId"] as int?;
}

<div id="FamilyChart" class="f3" style="width:100%; height:calc(100vh - 56px); position:relative;"></div>

<!-- GEDCOM toolbar (top-right corner) -->
<div style="position:fixed; top:66px; right:16px; z-index:1000; display:flex; gap:6px;">
    <a href="/api/gedcom/export" class="btn btn-sm btn-outline-secondary" title="Export GEDCOM" download>
        <i class="bi bi-download"></i>
    </a>
</div>

@section Styles {
    <link rel="stylesheet" href="~/lib/family-chart/dist/styles/family-chart.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/family-tree.css" asp-append-version="true" />
}

@section Scripts {
    <environment include="Development">
        <script src="~/lib/d3/dist/d3.js"></script>
        <script src="~/lib/family-chart/dist/family-chart.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/d3/dist/d3.min.js"></script>
        <script src="~/lib/family-chart/dist/family-chart.js"></script>
    </environment>
    <script>
        const isAdmin = @(isAdmin ? "true" : "false");
        const myPersonId = @(myPersonId.HasValue ? myPersonId.Value.ToString() : "null");
    </script>
    <script src="~/js/family-tree.js" asp-append-version="true"></script>
}
