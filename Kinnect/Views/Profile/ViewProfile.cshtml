@{
    ViewData["Title"] = "Profile";
    var personId = ViewData["PersonId"];
    bool isAdmin = (bool)(ViewData["IsAdmin"] ?? false);
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div data-bind="visible: loading" class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <div data-bind="visible: !loading()">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div data-bind="if: profileImagePath">
                            <img data-bind="attr: { src: '/uploads/' + profileImagePath() }" class="rounded-circle me-3" width="100" height="100" alt="Profile" style="object-fit:cover;" />
                        </div>
                        <div data-bind="ifnot: profileImagePath">
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width:100px;height:100px;font-size:2.5rem;">
                                <i class="bi bi-person"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <h3 data-bind="text: fullName" class="mb-0"></h3>
                            <small class="text-muted" data-bind="text: birthInfo"></small>
                        </div>
                        <div class="ms-3 d-flex gap-2 flex-wrap justify-content-end">
                            <div data-bind="if: canEdit">
                                <a data-bind="attr: { href: canEditOwn() ? '/Profile' : '/Profile/Edit/' + personId }" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit Profile
                                </a>
                            </div>
                            @if (isAdmin)
                            {
                                <button class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#linkUserModal" data-bind="visible: !hasAccount()">
                                    <i class="bi bi-person-badge"></i> Link User Account
                                </button>
                                <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#unlinkUserModal" data-bind="visible: hasAccount">
                                    <i class="bi bi-person-x"></i> Unlink User Account
                                </button>
                            }
                        </div>
                    </div>

                    <div data-bind="if: bio">
                        <h6>About</h6>
                        <p data-bind="text: bio"></p>
                    </div>

                    <div data-bind="if: occupation" class="mt-1">
                        <i class="bi bi-briefcase text-muted me-1"></i>
                        <span data-bind="text: occupation" class="text-muted small"></span>
                    </div>
                    <div data-bind="if: education" class="mt-1">
                        <i class="bi bi-mortarboard text-muted me-1"></i>
                        <span data-bind="text: education" class="text-muted small"></span>
                    </div>
                    <div data-bind="if: religion" class="mt-1">
                        <i class="bi bi-heart text-muted me-1"></i>
                        <span data-bind="text: religion" class="text-muted small"></span>
                    </div>
                </div>
            </div>

            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#postsTab">Posts</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#timelineTab">Timeline</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#mediaTab">Media</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#documentsTab">Documents</button>
                </li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="postsTab">
                    <div data-bind="foreach: posts">
                        <div class="card mb-2">
                            <div class="card-body">
                                <p data-bind="text: content"></p>
                                <small class="text-muted" data-bind="text: $root.formatDateTime(createdAtUtc)"></small>
                            </div>
                        </div>
                    </div>
                    <div data-bind="visible: posts().length === 0" class="text-muted text-center py-3">No posts yet.</div>
                </div>

                <div class="tab-pane fade" id="timelineTab">
                    <div data-bind="visible: timelineItems().length === 0" class="text-muted text-center py-3">No life events recorded.</div>
                    <div class="mb-3">
                        <a class="btn btn-sm btn-outline-secondary" data-bind="visible: hasEventMapItems, attr: { href: '/Profile/EventMap/' + personId }">
                            <i class="bi bi-map"></i> View Map
                        </a>
                    </div>
                    <div class="timeline" data-bind="foreach: timelineItems">
                        <div class="d-flex mb-3">
                            <div class="timeline-icon me-3 flex-shrink-0">
                                <div class="rounded-circle text-white d-flex align-items-center justify-content-center"
                                     style="width:40px;height:40px;"
                                     data-bind="css: { 'bg-primary': _source === 'event', 'bg-secondary': _source === 'spouse' }">
                                    <i data-bind="attr: { class: 'bi ' + $root.eventIcon(eventType) }"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="card">
                                    <div class="card-body py-2 px-3">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong data-bind="text: eventTypeLabel || eventType"></strong>
                                                <!-- ko if: _source === 'spouse' -->
                                                <span class="badge bg-secondary ms-1" style="font-size:.7rem;">via spouse</span>
                                                <!-- /ko -->
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-muted small" data-bind="text: $data.dateDisplay != null && $data.dateDisplay !== '' ? $data.dateDisplay : ($data.year != null ? $data.year : '')"></span>
                                                <!-- ko if: $root.canEdit() && _source === 'event' -->
                                                <button type="button" class="btn btn-sm btn-link p-0" data-bind="click: $root.startEditEvent" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <!-- /ko -->
                                            </div>
                                        </div>
                                        <div data-bind="if: place" class="text-muted small">
                                            <i class="bi bi-geo-alt"></i> <span data-bind="text: place"></span>
                                        </div>
                                        <div data-bind="if: description" class="small mt-1">
                                            <span data-bind="text: description"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Media tab: Photos + Videos -->
                <div class="tab-pane fade" id="mediaTab">
                    <div class="d-flex gap-2 mb-3">
                        <button class="btn btn-sm btn-outline-secondary" data-bind="click: goBackFromFolder, visible: inMediaFolder">
                            <i class="bi bi-arrow-left"></i> Go Back
                        </button>
                    </div>

                    <h6 class="text-muted small text-uppercase mb-2" data-bind="visible: inMediaFolder">Folder: <span data-bind="text: currentMediaFolderName"></span></h6>

                    <div class="row mb-3" data-bind="visible: !inMediaFolder() && mediaFolders().length > 0, foreach: mediaFolders">
                        <div class="col-md-3 col-sm-4 col-6 mb-3">
                            <div class="card h-100">
                                <div class="card-body text-center position-relative">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger position-absolute top-0 end-0 m-1"
                                            title="Delete folder"
                                            data-bind="visible: $root.canManageFolder($data), click: function(data, event) { $root.deleteMediaFolder(data, null, event); }">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                    <a href="#" class="text-decoration-none" data-bind="click: function() { $root.openMediaFolder($data); return false; }">
                                        <img src="~/img/Folder.png" alt="Folder" style="width:64px;height:64px;object-fit:contain;" />
                                        <div class="fw-semibold small mt-2" data-bind="text: name"></div>
                                        <div class="text-muted small">
                                            <span data-bind="text: $root.folderPhotoCount(id)"></span> photos ·
                                            <span data-bind="text: $root.folderVideoCount(id)"></span> videos
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3" data-bind="visible: !inMediaFolder() && hasTaggedMedia()">
                        <div class="col-md-3 col-sm-4 col-6 mb-3">
                            <a href="#" class="text-decoration-none" data-bind="click: function() { openTaggedMediaFolder(); return false; }">
                                <div class="card h-100 border-secondary">
                                    <div class="card-body text-center">
                                        <img src="~/img/Folder.png" alt="Tagged" style="width:64px;height:64px;object-fit:contain;" />
                                        <div class="fw-semibold small mt-2">Tagged</div>
                                        <div class="text-muted small">
                                            <span data-bind="text: taggedPhotoCount()"></span> photos ·
                                            <span data-bind="text: taggedVideoCount()"></span> videos
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>

                    <!-- Photos grid -->
                    <div data-bind="visible: visiblePhotos().length > 0">
                        <h6 class="text-muted small text-uppercase mb-2" data-bind="text: inMediaFolder() ? 'Photos' : 'Ungrouped Photos'"></h6>
                        <div class="row" data-bind="foreach: visiblePhotos">
                            <div class="col-md-3 mb-3">
                                <div class="card">
                                    <a href="#" class="d-block" data-bind="click: function() { $root.openPhotoLightbox($data); return false; }">
                                        <img data-bind="attr: { src: '/uploads/' + (thumbnailPath || filePath) }" class="card-img-top" alt="" style="height:200px; object-fit:cover; cursor:pointer;" role="button" />
                                    </a>
                                    <div class="card-body p-2">
                                        <div class="d-flex justify-content-between align-items-start gap-1">
                                            <div>
                                                <small class="fw-semibold" data-bind="text: title"></small>
                                                <div class="text-muted small" data-bind="visible: yearTaken || monthTaken || dayTaken, text: $root.formatPhotoDate($data)"></div>
                                            </div>
                                            <!-- ko if: $root.canEditMedia($data) -->
                                            <div class="d-flex gap-1">
                                                <button type="button" class="btn btn-sm btn-outline-secondary flex-shrink-0" title="Edit" data-bind="click: function() { $root.startEditPhoto($data); }">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0" title="Delete" data-bind="click: function() { $root.deletePhoto($data); }">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                            <!-- /ko -->
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Videos list -->
                    <div data-bind="visible: visibleVideos().length > 0" class="mt-2">
                        <h6 class="text-muted small text-uppercase mb-2" data-bind="text: inMediaFolder() ? 'Videos' : 'Ungrouped Videos'"></h6>
                        <div data-bind="foreach: visibleVideos">
                            <div class="card mb-2">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div><i class="bi bi-film"></i> <span data-bind="text: title"></span></div>
                                    <div class="d-flex gap-1" data-bind="visible: $root.canEditMedia($data)">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" title="Edit" data-bind="click: function() { $root.startEditVideo($data); }">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Delete" data-bind="click: function() { $root.deleteVideo($data); }">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div data-bind="visible: visiblePhotos().length === 0 && visibleVideos().length === 0 && (inMediaFolder() || mediaFolders().length === 0)" class="text-muted text-center py-3">No media yet.</div>
                </div>

                <div class="tab-pane fade" id="documentsTab">
                    <div data-bind="foreach: documents">
                        <div class="card mb-2">
                            <div class="card-body">
                                <i class="bi bi-file-earmark"></i> <a data-bind="text: title, attr: { href: '/uploads/' + filePath }" target="_blank"></a>
                            </div>
                        </div>
                    </div>
                    <div data-bind="visible: documents().length === 0" class="text-muted text-center py-3">No documents yet.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Photo lightbox with Annotorious + person tagging -->
<div class="modal fade" id="photoLightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-fullscreen-lg-down">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header border-secondary py-2">
                <div class="flex-grow-1 me-2">
                    <span class="fw-semibold" data-bind="text: lightboxPhotoTitle"></span>
                    <small class="ms-2 text-white-50" data-bind="text: lightboxPhotoDate"></small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="d-flex flex-column flex-lg-row" style="min-height:60vh;">
                    <!-- Image area -->
                    <div id="lightboxImageArea" class="flex-grow-1 d-flex align-items-center justify-content-center p-2" style="overflow:visible;">
                        <img id="lightboxAnnotatableImage" data-bind="attr: { src: photoLightboxUrl }" class="img-fluid rounded" style="max-height:80vh; max-width:100%;" alt="" />
                    </div>
                    <!-- Side panel -->
                    <div class="border-start border-secondary p-3" style="min-width:220px; max-width:280px; overflow-y:auto;">
                        <h6 class="text-white-50 small text-uppercase mb-2">People in this photo</h6>
                        <div data-bind="foreach: lightboxTaggedPeople">
                            <div class="d-flex align-items-center mb-1">
                                <a class="text-white text-decoration-none small" data-bind="text: name, attr: { href: '/Profile/View/' + personId }"></a>
                                <button class="btn btn-sm p-0 ms-auto text-danger" title="Remove tag"
                                        data-bind="visible: $root.lightboxCanEdit(), click: function() { $root.untagPersonFromLightbox(personId); }">
                                    <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                </button>
                            </div>
                        </div>
                        <div data-bind="visible: lightboxTaggedPeople().length === 0" class="text-white-50 small mb-2">Nobody tagged yet.</div>

                        <div class="mt-2 position-relative" data-bind="visible: lightboxCanEdit">
                            <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                                   id="lightboxPersonTagInput"
                                   placeholder="#Type a name to tag…"
                                   autocomplete="off"
                                   data-bind="textInput: lightboxPersonTagQuery" />
                            <div data-bind="visible: lightboxPersonTagResults().length > 0"
                                 class="list-group shadow"
                                 style="position:absolute; z-index:1100; width:100%; top:100%;">
                                <div data-bind="foreach: lightboxPersonTagResults">
                                    <button class="list-group-item list-group-item-action py-1 small"
                                            data-bind="text: fullName, click: function() { $root.tagPersonFromLightbox($data); }"></button>
                                </div>
                            </div>
                        </div>

                        <hr class="border-secondary my-3" />

                        <h6 class="text-white-50 small text-uppercase mb-2">Annotations</h6>
                        <div class="form-check mb-2" data-bind="visible: !lightboxCanEdit() && lightboxHasAnnotations()">
                            <input class="form-check-input" type="checkbox" id="viewProfileLightboxShowAnnotations" data-bind="checked: lightboxShowAnnotations" />
                            <label class="form-check-label small text-white-50" for="viewProfileLightboxShowAnnotations">Show annotations</label>
                        </div>
                        <div class="text-white-50 small mb-2" data-bind="visible: !lightboxCanEdit()">Read-only</div>
                        <!-- ko if: lightboxCanEdit() -->
                        <div class="d-grid gap-1 mb-2">
                            <button class="btn btn-sm btn-outline-light" data-bind="click: function(){ setAnnotationTool('rectangle'); }">
                                <i class="bi bi-bounding-box"></i> Rectangle
                            </button>
                            <button class="btn btn-sm btn-outline-light" data-bind="click: function(){ setAnnotationTool('polygon'); }">
                                <i class="bi bi-pentagon"></i> Polygon
                            </button>
                            <button class="btn btn-sm btn-outline-light" data-bind="click: editSelectedAnnotationText">
                                <i class="bi bi-chat-left-text"></i> Edit Text
                            </button>
                            <button class="btn btn-sm btn-outline-danger" data-bind="click: deleteSelectedAnnotation">
                                <i class="bi bi-trash"></i> Delete Selected
                            </button>
                        </div>
                        <!-- /ko -->
                        <button class="btn btn-sm btn-outline-light w-100" data-bind="visible: lightboxCanEdit(), click: saveLightboxAnnotations">
                            <i class="bi bi-floppy"></i> Save annotations
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit photo -->
<div class="modal fade" id="editPhotoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit photo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control" data-bind="value: editPhotoTitle" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" data-bind="value: editPhotoDescription"></textarea>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-4">
                        <label class="form-label">Year</label>
                        <input type="number" class="form-control" placeholder="YYYY" data-bind="value: editPhotoYear" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">Month</label>
                        <select class="form-select" data-bind="options: MONTHS, value: editPhotoMonth, optionsValue: 'v', optionsText: 'l'"></select>
                    </div>
                    <div class="col-4">
                        <label class="form-label">Day</label>
                        <select class="form-select" data-bind="options: editPhotoDayOptions, value: editPhotoDay, optionsText: function(v){ return v == null ? '— Day —' : v; }"></select>
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label">Tags (comma-separated)</label>
                    <input type="text" class="form-control" data-bind="value: editPhotoTagsText" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Folder</label>
                    <select class="form-select" data-bind="options: mediaFolders, value: editPhotoFolderId, optionsValue: 'id', optionsText: 'name', optionsCaption: '— No folder —'"></select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: saveEditPhoto">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit video -->
<div class="modal fade" id="editVideoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit video</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control" data-bind="value: editVideoTitle" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" data-bind="value: editVideoDescription"></textarea>
                </div>
                <div class="mb-2">
                    <label class="form-label">Tags (comma-separated)</label>
                    <input type="text" class="form-control" data-bind="value: editVideoTagsText" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Folder</label>
                    <select class="form-select" data-bind="options: mediaFolders, value: editVideoFolderId, optionsValue: 'id', optionsText: 'name', optionsCaption: '— No folder —'"></select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: saveEditVideo">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit life event -->
<div class="modal fade" id="editEventModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit life event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label">Event type</label>
                    <select class="form-select" data-bind="value: editEventType">
                        <option value="BIRT">Birth</option>
                        <option value="DEAT">Death</option>
                        <option value="BAPM">Baptism</option>
                        <option value="CHR">Christening</option>
                        <option value="CONF">Confirmation</option>
                        <option value="ADOP">Adoption</option>
                        <option value="EMIG">Emigration</option>
                        <option value="IMMI">Immigration</option>
                        <option value="NATU">Naturalization</option>
                        <option value="MARB">Marriage Banns</option>
                        <option value="MARL">Marriage License</option>
                        <option value="BURI">Burial</option>
                        <option value="CREM">Cremation</option>
                        <option value="RESI">Residence</option>
                        <option value="EVEN">Custom Event</option>
                    </select>
                </div>
                <div class="row g-2">
                    <div class="col-4">
                        <label class="form-label">Year</label>
                        <input type="number" class="form-control" data-bind="value: editEventYear" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">Month</label>
                        <select class="form-select" data-bind="options: MONTHS, value: editEventMonth, optionsValue: 'v', optionsText: 'l'"></select>
                    </div>
                    <div class="col-4">
                        <label class="form-label">Day</label>
                        <select class="form-select" data-bind="options: editEventDayOptions, value: editEventDay, optionsText: function(v){ return v == null ? '— Day —' : v; }"></select>
                    </div>
                </div>
                <div class="mb-2 mt-2">
                    <label class="form-label">Place</label>
                    <input type="text" class="form-control" data-bind="value: editEventPlace" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Description</label>
                    <input type="text" class="form-control" data-bind="value: editEventDescription" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: saveEditEvent">Save</button>
            </div>
        </div>
    </div>
</div>

@if (isAdmin)
{
    <!-- Link User Account Modal -->
    <div class="modal fade" id="linkUserModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-badge"></i> Link User Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">Select a user account to link to this person record.</p>
                    <select id="userSelect" class="form-select">
                        <option value="">Loading users...</option>
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-warning" onclick="linkUserAccount()">
                        <i class="bi bi-person-badge"></i> Link Account
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Unlink User Account Modal -->
    <div class="modal fade" id="unlinkUserModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-x"></i> Unlink User Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to unlink the user account from this person record? The user will no longer be able to edit this profile.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" onclick="unlinkUserAccount()">
                        <i class="bi bi-person-x"></i> Unlink
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/annotorious/annotorious/dist/annotorious.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/lib/annotorious/annotorious/dist/annotorious.min.css" />
    </environment>
}

@section Scripts {
    <script>
        const viewPersonId = @personId;
        const isAdmin = @(isAdmin ? "true" : "false");
    </script>
    <environment include="Development">
        <script src="~/lib/annotorious/annotorious/dist/annotorious.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/annotorious/annotorious/dist/annotorious.min.js"></script>
    </environment>
    <script src="~/js/view-profile.js" asp-append-version="true"></script>
    @if (isAdmin)
    {
        <script>
        document.getElementById('linkUserModal')?.addEventListener('show.bs.modal', async () => {
            const select = document.getElementById('userSelect');
            select.innerHTML = '<option value="">Loading...</option>';
            const [usersRes, peopleRes] = await Promise.all([
                fetch('/api/people/users'),
                fetch('/api/people')
            ]);

            if (!usersRes.ok || !peopleRes.ok) {
                select.innerHTML = '<option value="">Failed to load users</option>';
                return;
            }

            const [users, peopleResult] = await Promise.all([
                usersRes.json(),
                peopleRes.json()
            ]);
            const people = peopleResult?.value || peopleResult || [];
            const linkedUserIds = new Set(
                people
                    .filter(p => p?.userId)
                    .map(p => p.userId)
            );
            const availableUsers = users.filter(u => u?.userId && !linkedUserIds.has(u.userId));

            select.innerHTML = '<option value="">-- Select a user --</option>' +
                availableUsers.map(u => `<option value="${u.userId}">${u.username} (${u.email})</option>`).join('');
        });

        async function linkUserAccount() {
            const userId = document.getElementById('userSelect').value;
            if (!userId) return;
            const res = await fetch(`/api/people/${viewPersonId}/link-user`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId })
            });
            if (res.ok) {
                bootstrap.Modal.getInstance(document.getElementById('linkUserModal'))?.hide();
                location.reload();
            } else {
                const err = await res.json();
                alert('Failed to link: ' + (err?.title || JSON.stringify(err)));
            }
        }

        async function unlinkUserAccount() {
            const res = await fetch(`/api/people/${viewPersonId}/link-user`, { method: 'DELETE' });
            if (res.ok) {
                bootstrap.Modal.getInstance(document.getElementById('unlinkUserModal'))?.hide();
                location.reload();
            } else {
                alert('Failed to unlink user account.');
            }
        }
        </script>
    }
}
