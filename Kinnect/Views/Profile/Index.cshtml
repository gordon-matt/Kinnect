@{
    ViewData["Title"] = ViewData["EditPersonId"] != null ? "Edit profile" : "My Profile";
    var editPersonId = ViewData["EditPersonId"] as int?;
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/leaflet/dist/leaflet.css" />
        <link rel="stylesheet" href="~/lib/annotorious/annotorious/dist/annotorious.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/lib/leaflet/dist/leaflet.min.css" />
        <link rel="stylesheet" href="~/lib/annotorious/annotorious/dist/annotorious.min.css" />
    </environment>
    <style>
        .profile-map-search { z-index: 1000; max-height: 200px; overflow-y: auto; }
        .profile-map-search .search-hit:hover { background: #f0f0f0; }
        #profileLocationMap { z-index: 1; }
        .event-mini-map { height: 220px; border-radius: .375rem; z-index: 1; }
        .event-map-search { z-index: 1000; max-height: 160px; overflow-y: auto; }
        .event-map-search .search-hit:hover { background: #f0f0f0; }
        .spouse-event-badge { font-size: .75rem; }
    </style>
}

<div class="row">
    <div class="col-md-8 mx-auto">
        @if (editPersonId.HasValue)
        {
            <div class="alert alert-info d-flex justify-content-between align-items-center">
                <span><i class="bi bi-pencil-square"></i> You are editing another person&rsquo;s profile.</span>
                <a class="btn btn-sm btn-outline-secondary" href="/Profile/View/@editPersonId.Value">View profile</a>
            </div>
        }
        <div data-bind="visible: loading" class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <div data-bind="visible: !loading()">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="position-relative me-3">
                            <div data-bind="if: profileImagePath">
                                <img data-bind="attr: { src: '/uploads/' + profileImagePath() }" class="rounded-circle" width="100" height="100" alt="Profile" style="object-fit: cover;" />
                            </div>
                            <div data-bind="ifnot: profileImagePath">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width:100px;height:100px;font-size:2.5rem;">
                                    <i class="bi bi-person"></i>
                                </div>
                            </div>
                            <label class="position-absolute bottom-0 end-0 btn btn-sm btn-primary rounded-circle" style="width:32px;height:32px;padding:0;line-height:32px;">
                                <i class="bi bi-camera"></i>
                                <input type="file" accept="image/*" class="d-none" data-bind="event: { change: uploadProfileImage }" />
                            </label>
                        </div>
                        <div>
                            <h3 data-bind="text: fullName" class="mb-0"></h3>
                            <small class="text-muted d-block" data-bind="text: subtitleLine"></small>
                            <small class="text-muted" data-bind="visible: latitude() != null && longitude() != null, text: coordinateLine"></small>
                        </div>
                    </div>

                    <form data-bind="submit: saveProfile">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Given Names</label>
                                <input type="text" class="form-control" data-bind="value: givenNames" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Family Name</label>
                                <input type="text" class="form-control" data-bind="value: familyName" />
                            </div>
                        </div>
                        <p class="text-muted small mb-3">Birth and death dates are managed on the <strong>Timeline</strong> tab as life events.</p>
                        <div class="mb-3">
                            <label class="form-label">Bio</label>
                            <textarea class="form-control" rows="3" data-bind="value: bio"></textarea>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Gender</label>
                                <select class="form-select" data-bind="value: isMaleStr">
                                    <option value="true">Male</option>
                                    <option value="false">Female</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Occupation</label>
                                <input type="text" class="form-control" data-bind="value: occupation" placeholder="e.g. Teacher, Engineer…" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Education</label>
                                <input type="text" class="form-control" data-bind="value: education" placeholder="e.g. BSc Computer Science" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Religion</label>
                                <input type="text" class="form-control" data-bind="value: religion" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea class="form-control" rows="2" data-bind="value: note" placeholder="Any additional notes…"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Current or last known location</label>
                            <p class="text-muted small">Search for an address or click the map to place the pin. Appears on the family map when the person has no death event.</p>
                            <div class="position-relative border rounded overflow-hidden" style="background:#e9ecef;">
                                <div class="position-absolute m-2 bg-white rounded shadow-sm p-2" style="width:min(300px, calc(100% - 1rem)); z-index:500;">
                                    <input type="search" class="form-control form-control-sm" placeholder="Search address…" autocomplete="off" data-bind="textInput: locationSearchQuery" />
                                    <div class="profile-map-search small border-top mt-1 pt-1" data-bind="foreach: locationSearchResults">
                                        <div class="search-hit px-1 py-1" style="cursor:pointer;" data-bind="text: display_name, click: function() { $root.pickLocationSearchResult($data); }"></div>
                                    </div>
                                </div>
                                <div id="profileLocationMap" style="height:260px;"></div>
                            </div>
                        </div>

                        <h6 class="mt-4">Spouse relationships</h6>
                        <p class="text-muted small">Tick the boxes below to record engagement, marriage, or divorce details for each couple.</p>
                        <div data-bind="visible: spouses().length === 0" class="text-muted small mb-2">No spouse links recorded.</div>
                        <div data-bind="foreach: spouses" class="mb-3">
                            <div class="card mb-2">
                                <div class="card-body py-2">
                                    <div class="fw-semibold mb-2">
                                        <a data-bind="attr: { href: '/Profile/View/' + spousePersonId }, text: displayName"></a>
                                    </div>
                                    <div class="d-flex flex-wrap gap-3 mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" data-bind="checked: hasEngagement, attr: { id: 'chkEnga_' + spousePersonId }" />
                                            <label class="form-check-label small" data-bind="attr: { for: 'chkEnga_' + spousePersonId }">Add Engagement</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" data-bind="checked: hasMarriage, attr: { id: 'chkMarr_' + spousePersonId }" />
                                            <label class="form-check-label small" data-bind="attr: { for: 'chkMarr_' + spousePersonId }">Add Marriage</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" data-bind="checked: hasDivorce, attr: { id: 'chkDiv_' + spousePersonId }" />
                                            <label class="form-check-label small" data-bind="attr: { for: 'chkDiv_' + spousePersonId }">Add Divorce</label>
                                        </div>
                                    </div>
                                    <div class="row g-2 small" data-bind="visible: hasEngagement">
                                        <div class="col-12 text-muted fw-semibold">Engagement</div>
                                        <div class="col-4">
                                            <input type="number" class="form-control form-control-sm" placeholder="Year" data-bind="value: engagementYear" />
                                        </div>
                                        <div class="col-4">
                                            <select class="form-select form-select-sm" data-bind="options: $root.MONTHS, value: engagementMonth, optionsValue: 'v', optionsText: 'l'"></select>
                                        </div>
                                        <div class="col-4">
                                            <select class="form-select form-select-sm" data-bind="options: engagementDayOptions, value: engagementDay, optionsText: function(v){ return v == null ? '— Day —' : v; }"></select>
                                        </div>
                                    </div>
                                    <div class="row g-2 small" data-bind="visible: hasMarriage">
                                        <div class="col-12 text-muted fw-semibold">Marriage</div>
                                        <div class="col-4">
                                            <input type="number" class="form-control form-control-sm" placeholder="Year" data-bind="value: marriageYear" />
                                        </div>
                                        <div class="col-4">
                                            <select class="form-select form-select-sm" data-bind="options: $root.MONTHS, value: marriageMonth, optionsValue: 'v', optionsText: 'l'"></select>
                                        </div>
                                        <div class="col-4">
                                            <select class="form-select form-select-sm" data-bind="options: marriageDayOptions, value: marriageDay, optionsText: function(v){ return v == null ? '— Day —' : v; }"></select>
                                        </div>
                                    </div>
                                    <div class="row g-2 small" data-bind="visible: hasDivorce">
                                        <div class="col-12 text-muted fw-semibold">Divorce</div>
                                        <div class="col-4">
                                            <input type="number" class="form-control form-control-sm" placeholder="Year" data-bind="value: divorceYear" />
                                        </div>
                                        <div class="col-4">
                                            <select class="form-select form-select-sm" data-bind="options: $root.MONTHS, value: divorceMonth, optionsValue: 'v', optionsText: 'l'"></select>
                                        </div>
                                        <div class="col-4">
                                            <select class="form-select form-select-sm" data-bind="options: divorceDayOptions, value: divorceDay, optionsText: function(v){ return v == null ? '— Day —' : v; }"></select>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-primary mt-2" data-bind="click: function() { $root.saveSpouseRow($data); }">Save dates</button>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
                    </form>
                </div>
            </div>

            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#postsTab">Posts</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#timelineTab">Timeline</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#mediaTab">Media</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#documentsTab">Documents</button>
                </li>
            </ul>

            <div class="tab-content">
                <!-- Posts tab (item 3) -->
                <div class="tab-pane fade show active" id="postsTab">
                    <div data-bind="foreach: posts">
                        <div class="card mb-2">
                            <div class="card-body">
                                <p data-bind="text: content"></p>
                                <small class="text-muted" data-bind="text: $root.formatDateTime(createdAtUtc)"></small>
                            </div>
                        </div>
                    </div>
                    @await Html.PartialAsync("_Pager", new Kinnect.Models.PagerViewModel(
                        AriaLabel: "Posts pagination",
                        CurrentPageExpr: "postsCurrentPage",
                        TotalPagesExpr: "postsTotalPages",
                        TotalCountExpr: "postsTotalCount",
                        PageNumbersExpr: "postsPageNumbers",
                        PreviousPageFn: "postsPreviousPage",
                        NextPageFn: "postsNextPage",
                        GoToPageFn: "postsGoToPage",
                        ItemLabel: "posts"))
                </div>

                <!-- Timeline tab (items 1, 7, 8, 9, 10) -->
                <div class="tab-pane fade" id="timelineTab">
                    <div data-bind="visible: timelineItems().length === 0" class="text-muted text-center py-3">
                        No life events recorded yet.
                    </div>
                    <!-- Event add form -->
                    <div class="mb-3 d-flex gap-2 flex-wrap">
                        <button class="btn btn-sm btn-outline-primary" data-bind="click: showAddEvent, visible: !isAddingEvent()">
                            <i class="bi bi-plus"></i> Add Event
                        </button>
                        <!-- item 7: View Map button -->
                        <a class="btn btn-sm btn-outline-secondary" data-bind="visible: hasEventMapItems, attr: { href: '/Profile/EventMap/' + personId() }">
                            <i class="bi bi-map"></i> View Map
                        </a>
                    </div>
                    <div data-bind="visible: isAddingEvent" class="card mt-2 mb-3">
                        <div class="card-body">
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="form-label form-label-sm">Event Type</label>
                                    <select class="form-select form-select-sm" data-bind="value: newEventType">
                                        <option value="BIRT">Birth</option>
                                        <option value="DEAT">Death</option>
                                        <option value="BAPM">Baptism</option>
                                        <option value="CHR">Christening</option>
                                        <option value="CONF">Confirmation</option>
                                        <option value="ADOP">Adoption</option>
                                        <option value="EMIG">Emigration</option>
                                        <option value="IMMI">Immigration</option>
                                        <option value="NATU">Naturalization</option>
                                        <option value="MARB">Marriage Banns</option>
                                        <option value="MARL">Marriage License</option>
                                        <option value="BURI">Burial</option>
                                        <option value="CREM">Cremation</option>
                                        <option value="RESI">Residence</option>
                                        <option value="EVEN">Custom Event</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label form-label-sm">Year</label>
                                    <input type="number" class="form-control form-control-sm" data-bind="value: newEventYear" placeholder="YYYY" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label form-label-sm">Month</label>
                                    <select class="form-select form-select-sm" data-bind="options: MONTHS, value: newEventMonth, optionsValue: 'v', optionsText: 'l'"></select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label form-label-sm">Day</label>
                                    <select class="form-select form-select-sm" data-bind="options: newEventDayOptions, value: newEventDay, optionsText: function(v){ return v == null ? '— Day —' : v; }"></select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label form-label-sm">Description</label>
                                    <input type="text" class="form-control form-control-sm" data-bind="value: newEventDescription" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label form-label-sm">Place</label>
                                    <p class="text-muted small mb-2">Search for an address or click the map to place the pin. The place name and coordinates are set together from a search result.</p>
                                    <div class="position-relative border rounded overflow-hidden" style="background:#e9ecef;">
                                        <div class="position-absolute m-2 bg-white rounded shadow-sm p-2" style="width:min(320px, calc(100% - 1rem)); z-index:500;">
                                            <input type="search" class="form-control form-control-sm" placeholder="Search address…" autocomplete="off" data-bind="textInput: newEventLocationSearchQuery" />
                                            <div class="event-map-search small border-top mt-1 pt-1" data-bind="foreach: newEventLocationSearchResults">
                                                <div class="search-hit px-1 py-1" style="cursor:pointer;" data-bind="text: display_name, click: function() { $root.pickNewEventLocationResult($data); }"></div>
                                            </div>
                                        </div>
                                        <div id="newEventMap" class="event-mini-map"></div>
                                    </div>
                                    <div class="text-muted small mt-1" data-bind="visible: newEventLatitude() != null">
                                        <span data-bind="text: newEventPlace() ? newEventPlace() : ''"></span>
                                        <span class="ms-1" data-bind="visible: newEventLatitude() != null">·</span>
                                        <span data-bind="text: newEventLatitude() != null ? Number(newEventLatitude()).toFixed(5) + ', ' + Number(newEventLongitude()).toFixed(5) : ''"></span>
                                        <a href="#" class="ms-2 small" data-bind="click: clearNewEventPlace">Clear</a>
                                    </div>
                                    <div class="mt-2">
                                        <label class="form-label form-label-sm mb-0">Place name (editable)</label>
                                        <input type="text" class="form-control form-control-sm" data-bind="value: newEventPlace" placeholder="Filled when you pick a search result; you can shorten or edit the text." />
                                    </div>
                                </div>
                            </div>
                            <div class="mt-2">
                                <button class="btn btn-primary btn-sm" data-bind="click: addEvent">Save</button>
                                <button class="btn btn-secondary btn-sm ms-1" data-bind="click: cancelAddEvent">Cancel</button>
                            </div>
                        </div>
                    </div>

                    <div class="timeline" data-bind="foreach: timelineItems">
                        <div class="d-flex mb-3">
                            <div class="timeline-icon me-3 flex-shrink-0">
                                <div class="rounded-circle text-white d-flex align-items-center justify-content-center"
                                     style="width:40px;height:40px;"
                                     data-bind="css: { 'bg-primary': _source === 'event', 'bg-secondary': _source === 'spouse' }">
                                    <i data-bind="attr: { class: 'bi ' + $root.eventIcon(eventType) }"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="card">
                                    <div class="card-body py-2 px-3">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong data-bind="text: eventTypeLabel || eventType"></strong>
                                                <!-- ko if: _source === 'spouse' -->
                                                <span class="badge bg-secondary ms-1 spouse-event-badge">via spouse</span>
                                                <!-- /ko -->
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-muted small" data-bind="text: $data.dateDisplay != null && $data.dateDisplay !== '' ? $data.dateDisplay : ($data.year != null ? $data.year : '')"></span>
                                                <!-- ko if: _source === 'event' -->
                                                <button type="button" class="btn btn-sm btn-link p-0" data-bind="click: $root.startEditEvent" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="btn btn-sm btn-link p-0 text-danger" data-bind="click: $root.deleteEvent.bind($root, id)" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                                <!-- ko if: $root.isCopyable(eventType) -->
                                                <button type="button" class="btn btn-sm btn-link p-0 text-secondary" data-bind="click: $root.openCopyEvent.bind($root, $data)" title="Copy to another person">
                                                    <i class="bi bi-person-plus"></i>
                                                </button>
                                                <!-- /ko -->
                                                <!-- /ko -->
                                            </div>
                                        </div>
                                        <div data-bind="if: place" class="text-muted small">
                                            <i class="bi bi-geo-alt"></i> <span data-bind="text: place"></span>
                                        </div>
                                        <div data-bind="if: description" class="small mt-1">
                                            <span data-bind="text: description"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Media tab: Photos + Videos -->
                <div class="tab-pane fade" id="mediaTab">
                    <div class="d-flex gap-2 mb-3">
                        <button class="btn btn-sm btn-outline-secondary" data-bind="click: showAddFolder, visible: !isAddingFolder() && !inMediaFolder()">
                            <i class="bi bi-folder-plus"></i> New Folder
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" data-bind="click: goBackFromFolder, visible: inMediaFolder">
                            <i class="bi bi-arrow-left"></i> Go Back
                        </button>
                        <button class="btn btn-sm btn-outline-primary" data-bind="click: showPhotoUpload, visible: !isUploadingPhoto()">
                            <i class="bi bi-image"></i> Upload Photo
                        </button>
                        <button class="btn btn-sm btn-outline-primary" data-bind="click: showVideoUpload, visible: !isUploadingVideo()">
                            <i class="bi bi-film"></i> Upload Video
                        </button>
                    </div>

                    <h6 class="text-muted small text-uppercase mb-2" data-bind="visible: inMediaFolder">Folder: <span data-bind="text: currentMediaFolderName"></span></h6>

                    <div data-bind="visible: isAddingFolder() && !inMediaFolder()" class="card mb-3">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <span class="fw-semibold"><i class="bi bi-folder-plus"></i> New Folder</span>
                            <button type="button" class="btn-close btn-sm" data-bind="click: cancelAddFolder"></button>
                        </div>
                        <div class="card-body">
                            <input type="text" class="form-control mb-2" placeholder="Folder name (e.g. Wedding)" data-bind="value: newFolderName" />
                            <input type="text" class="form-control mb-2" placeholder="Description (optional)" data-bind="value: newFolderDescription" />
                            <button class="btn btn-primary btn-sm" data-bind="click: createMediaFolder">Create Folder</button>
                            <button class="btn btn-secondary btn-sm ms-1" data-bind="click: cancelAddFolder">Cancel</button>
                        </div>
                    </div>

                    <div class="row mb-3" data-bind="visible: !inMediaFolder() && mediaFolders().length > 0, foreach: mediaFolders">
                        <div class="col-md-3 col-sm-4 col-6 mb-3">
                            <div class="card h-100">
                                <div class="card-body text-center position-relative">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger position-absolute top-0 end-0 m-1"
                                            title="Delete folder"
                                            data-bind="visible: $root.canManageFolder($data), click: function(data, event) { $root.deleteMediaFolder(data, null, event); }">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                    <a href="#" class="text-decoration-none" data-bind="click: function() { $root.openMediaFolder($data); return false; }">
                                        <img src="~/img/Folder.png" alt="Folder" style="width:64px;height:64px;object-fit:contain;" />
                                        <div class="fw-semibold small mt-2" data-bind="text: name"></div>
                                        <div class="text-muted small">
                                            <span data-bind="text: $root.folderPhotoCount(id)"></span> photos ·
                                            <span data-bind="text: $root.folderVideoCount(id)"></span> videos
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3" data-bind="visible: !inMediaFolder() && hasTaggedMedia()">
                        <div class="col-md-3 col-sm-4 col-6 mb-3">
                            <a href="#" class="text-decoration-none" data-bind="click: function() { openTaggedMediaFolder(); return false; }">
                                <div class="card h-100 border-secondary">
                                    <div class="card-body text-center">
                                        <img src="~/img/Folder.png" alt="Tagged" style="width:64px;height:64px;object-fit:contain;" />
                                        <div class="fw-semibold small mt-2">Tagged</div>
                                        <div class="text-muted small">
                                            <span data-bind="text: taggedPhotoCount()"></span> photos ·
                                            <span data-bind="text: taggedVideoCount()"></span> videos
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>

                    <!-- Photo upload form -->
                    <div data-bind="visible: isUploadingPhoto" class="card mb-3">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <span class="fw-semibold"><i class="bi bi-image"></i> New Photo</span>
                            <button type="button" class="btn-close btn-sm" data-bind="click: cancelPhotoUpload"></button>
                        </div>
                        <div class="card-body">
                            <input type="file" accept="image/*" class="form-control mb-2" id="photoFile" />
                            <input type="text" class="form-control mb-2" placeholder="Title" data-bind="value: photoTitle" />
                            <input type="text" class="form-control mb-2" placeholder="Description" data-bind="value: photoDescription" />
                            <div class="row g-2 mb-2">
                                <div class="col-4">
                                    <label class="form-label form-label-sm mb-0">Year</label>
                                    <input type="number" class="form-control form-control-sm" placeholder="YYYY" data-bind="value: photoYearTaken" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label form-label-sm mb-0">Month</label>
                                    <select class="form-select form-select-sm" data-bind="options: MONTHS, value: photoMonthTaken, optionsValue: 'v', optionsText: 'l'"></select>
                                </div>
                                <div class="col-4">
                                    <label class="form-label form-label-sm mb-0">Day</label>
                                    <select class="form-select form-select-sm" data-bind="options: photoUploadDayOptions, value: photoDayTaken, optionsText: function(v){ return v == null ? '— Day —' : v; }"></select>
                                </div>
                            </div>
                            <input id="photoTags" class="form-control mb-2" placeholder="Tags" />
                            <div class="mb-2">
                                <label class="form-label form-label-sm">Folder</label>
                                <select class="form-select form-select-sm" data-bind="options: mediaFolders, value: photoFolderId, optionsValue: 'id', optionsText: 'name', optionsCaption: '— No folder —'"></select>
                            </div>
                            <div data-bind="visible: events().length > 0" class="mb-2">
                                <label class="form-label form-label-sm">Link to events</label>
                                <div class="border rounded p-2" style="max-height:120px;overflow-y:auto;" data-bind="foreach: events">
                                    <div class="form-check form-check-sm">
                                        <input type="checkbox" class="form-check-input"
                                               data-bind="checked: $root.photoSelectedEventIds, checkedValue: id" />
                                        <label class="form-check-label small">
                                            <span data-bind="text: (eventTypeLabel || eventType) + (year ? ' (' + year + ')' : '')"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <button class="btn btn-primary btn-sm" data-bind="click: uploadPhoto">Upload</button>
                            <button class="btn btn-secondary btn-sm ms-1" data-bind="click: cancelPhotoUpload">Cancel</button>
                        </div>
                    </div>

                    <!-- Video upload form -->
                    <div data-bind="visible: isUploadingVideo" class="card mb-3">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <span class="fw-semibold"><i class="bi bi-film"></i> New Video</span>
                            <button type="button" class="btn-close btn-sm" data-bind="click: cancelVideoUpload"></button>
                        </div>
                        <div class="card-body">
                            <input type="file" accept="video/*" class="form-control mb-2" id="videoFile" />
                            <input type="text" class="form-control mb-2" placeholder="Title" data-bind="value: videoTitle" />
                            <input type="text" class="form-control mb-2" placeholder="Description" data-bind="value: videoDescription" />
                            <input id="videoTags" class="form-control mb-2" placeholder="Tags" />
                            <div class="mb-2">
                                <label class="form-label form-label-sm">Folder</label>
                                <select class="form-select form-select-sm" data-bind="options: mediaFolders, value: videoFolderId, optionsValue: 'id', optionsText: 'name', optionsCaption: '— No folder —'"></select>
                            </div>
                            <div data-bind="visible: events().length > 0" class="mb-2">
                                <label class="form-label form-label-sm">Link to events</label>
                                <div class="border rounded p-2" style="max-height:120px;overflow-y:auto;" data-bind="foreach: events">
                                    <div class="form-check form-check-sm">
                                        <input type="checkbox" class="form-check-input"
                                               data-bind="checked: $root.videoSelectedEventIds, checkedValue: id" />
                                        <label class="form-check-label small">
                                            <span data-bind="text: (eventTypeLabel || eventType) + (year ? ' (' + year + ')' : '')"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <button class="btn btn-primary btn-sm" data-bind="click: uploadVideo">Upload</button>
                            <button class="btn btn-secondary btn-sm ms-1" data-bind="click: cancelVideoUpload">Cancel</button>
                        </div>
                    </div>

                    <!-- Photos grid -->
                    <div data-bind="visible: visiblePhotos().length > 0">
                        <h6 class="text-muted small text-uppercase mb-2" data-bind="text: inMediaFolder() ? 'Photos' : 'Ungrouped Photos'"></h6>
                        <div class="row" data-bind="foreach: visiblePhotos">
                            <div class="col-md-3 mb-3">
                                <div class="card">
                                    <a href="#" class="d-block" data-bind="click: function() { $root.openPhotoLightbox($data); return false; }">
                                        <img data-bind="attr: { src: '/uploads/' + (thumbnailPath || filePath) }" class="card-img-top" alt="" style="height:200px; object-fit:cover; cursor:pointer;" role="button" />
                                    </a>
                                    <div class="card-body p-2">
                                        <div class="d-flex justify-content-between align-items-start gap-1">
                                            <div>
                                                <small class="fw-semibold" data-bind="text: title"></small>
                                                <div class="text-muted small" data-bind="visible: yearTaken || monthTaken || dayTaken, text: $root.formatPhotoDate($data)"></div>
                                            </div>
                                            <div class="d-flex gap-1">
                                                <button type="button" class="btn btn-sm btn-outline-secondary flex-shrink-0" title="Edit" data-bind="visible: $root.canEditMedia($data), click: function() { $root.startEditPhoto($data); }">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0" title="Delete" data-bind="visible: $root.canEditMedia($data), click: function() { $root.deletePhoto($data); }">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Videos list -->
                    <div data-bind="visible: visibleVideos().length > 0" class="mt-2">
                        <h6 class="text-muted small text-uppercase mb-2" data-bind="text: inMediaFolder() ? 'Videos' : 'Ungrouped Videos'"></h6>
                        <div data-bind="foreach: visibleVideos">
                            <div class="card mb-2">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div><i class="bi bi-film"></i> <span data-bind="text: title"></span></div>
                                    
                                    <!-- ko if: $root.canEditMedia($data) -->
                                    <div class="d-flex gap-1">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" title="Edit" data-bind="click: function() { $root.startEditVideo($data); }">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Delete" data-bind="click: function() { $root.deleteVideo($data); }">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                    <!-- /ko -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <div data-bind="visible: visiblePhotos().length === 0 && visibleVideos().length === 0 && (inMediaFolder() || mediaFolders().length === 0)" class="text-muted text-center py-3">
                        No media uploaded yet.
                    </div>
                </div>

                <div class="tab-pane fade" id="documentsTab">
                    <div class="mb-3">
                        <button class="btn btn-sm btn-outline-primary" data-bind="click: showDocumentUpload">
                            <i class="bi bi-upload"></i> Upload Document
                        </button>
                    </div>
                    <div data-bind="visible: isUploadingDocument" class="card mb-3">
                        <div class="card-body">
                            <input type="file" class="form-control mb-2" id="documentFile" />
                            <input type="text" class="form-control mb-2" placeholder="Title" data-bind="value: documentTitle" />
                            <input type="text" class="form-control mb-2" placeholder="Description" data-bind="value: documentDescription" />
                            <input id="documentTags" class="form-control mb-2" placeholder="Tags" />
                            <button class="btn btn-primary btn-sm" data-bind="click: uploadDocument">Upload</button>
                            <button class="btn btn-secondary btn-sm" data-bind="click: cancelDocumentUpload">Cancel</button>
                        </div>
                    </div>
                    <div data-bind="foreach: documents">
                        <div class="card mb-2">
                            <div class="card-body">
                                <i class="bi bi-file-earmark"></i> <a data-bind="text: title, attr: { href: '/uploads/' + filePath }" target="_blank"></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Photo lightbox with Annotorious + person tagging -->
<div class="modal fade" id="photoLightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-fullscreen-lg-down">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header border-secondary py-2">
                <div class="flex-grow-1 me-2">
                    <span class="fw-semibold" data-bind="text: lightboxPhotoTitle"></span>
                    <small class="ms-2 text-white-50" data-bind="text: lightboxPhotoDate"></small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="d-flex flex-column flex-lg-row" style="min-height:60vh;">
                    <!-- Image area -->
                    <div id="lightboxImageArea" class="flex-grow-1 d-flex align-items-center justify-content-center p-2" style="overflow:visible;">
                        <img id="lightboxAnnotatableImage" data-bind="attr: { src: photoLightboxUrl }" class="img-fluid rounded" style="max-height:80vh; max-width:100%;" alt="" />
                    </div>
                    <!-- Side panel -->
                    <div class="border-start border-secondary p-3" style="min-width:220px; max-width:280px; overflow-y:auto;">
                        <h6 class="text-white-50 small text-uppercase mb-2">People in this photo</h6>
                        <div data-bind="foreach: lightboxTaggedPeople">
                            <div class="d-flex align-items-center mb-1">
                                <a class="text-white text-decoration-none small" data-bind="text: name, attr: { href: '/Profile/View/' + personId }"></a>
                                <button class="btn btn-sm p-0 ms-auto text-danger" title="Remove tag"
                                        data-bind="visible: $root.lightboxCanEdit(), click: function() { $root.untagPersonFromLightbox(personId); }">
                                    <i class="bi bi-x-lg" style="font-size:.7rem;"></i>
                                </button>
                            </div>
                        </div>
                        <div data-bind="visible: lightboxTaggedPeople().length === 0" class="text-white-50 small mb-2">Nobody tagged yet.</div>

                        <!-- Person tagging input -->
                        <div class="mt-2 position-relative" data-bind="visible: lightboxCanEdit">
                            <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                                   id="lightboxPersonTagInput"
                                   placeholder="#Type a name to tag…"
                                   autocomplete="off"
                                   data-bind="textInput: lightboxPersonTagQuery" />
                            <div data-bind="visible: lightboxPersonTagResults().length > 0"
                                 class="list-group shadow"
                                 style="position:absolute; z-index:1100; width:100%; top:100%;">
                                <div data-bind="foreach: lightboxPersonTagResults">
                                    <button class="list-group-item list-group-item-action py-1 small"
                                            data-bind="text: fullName, click: function() { $root.tagPersonFromLightbox($data); }"></button>
                                </div>
                            </div>
                        </div>

                        <hr class="border-secondary my-3" />

                        <h6 class="text-white-50 small text-uppercase mb-2">Annotations</h6>
                        <div class="form-check mb-2" data-bind="visible: !lightboxCanEdit() && lightboxHasAnnotations()">
                            <input class="form-check-input" type="checkbox" id="profileLightboxShowAnnotations" data-bind="checked: lightboxShowAnnotations" />
                            <label class="form-check-label small text-white-50" for="profileLightboxShowAnnotations">Show annotations</label>
                        </div>
                        <div class="text-white-50 small mb-2" data-bind="visible: !lightboxCanEdit()">Read-only</div>
                        <!-- ko if: lightboxCanEdit() -->
                        <div class="d-grid gap-1 mb-2">
                            <button class="btn btn-sm btn-outline-light" data-bind="click: function(){ setAnnotationTool('rectangle'); }">
                                <i class="bi bi-bounding-box"></i> Rectangle
                            </button>
                            <button class="btn btn-sm btn-outline-light" data-bind="click: function(){ setAnnotationTool('polygon'); }">
                                <i class="bi bi-pentagon"></i> Polygon
                            </button>
                            <button class="btn btn-sm btn-outline-light" data-bind="click: editSelectedAnnotationText">
                                <i class="bi bi-chat-left-text"></i> Edit Text
                            </button>
                            <button class="btn btn-sm btn-outline-danger" data-bind="click: deleteSelectedAnnotation">
                                <i class="bi bi-trash"></i> Delete Selected
                            </button>
                        </div>
                        <!-- /ko -->
                        <button class="btn btn-sm btn-outline-light w-100" data-bind="visible: lightboxCanEdit(), click: saveLightboxAnnotations">
                            <i class="bi bi-floppy"></i> Save annotations
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit photo (items 9, 10, 11) -->
<div class="modal fade" id="editPhotoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit photo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control" data-bind="value: editPhotoTitle" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" data-bind="value: editPhotoDescription"></textarea>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-4">
                        <label class="form-label">Year</label>
                        <input type="number" class="form-control" placeholder="YYYY" data-bind="value: editPhotoYear" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">Month</label>
                        <select class="form-select" data-bind="options: MONTHS, value: editPhotoMonth, optionsValue: 'v', optionsText: 'l'"></select>
                    </div>
                    <div class="col-4">
                        <label class="form-label">Day</label>
                        <select class="form-select" data-bind="options: editPhotoDayOptions, value: editPhotoDay, optionsText: function(v){ return v == null ? '— Day —' : v; }"></select>
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label">Tags (comma-separated)</label>
                    <input type="text" class="form-control" data-bind="value: editPhotoTagsText" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Folder</label>
                    <select class="form-select" data-bind="options: mediaFolders, value: editPhotoFolderId, optionsValue: 'id', optionsText: 'name', optionsCaption: '— No folder —'"></select>
                </div>
                <!-- item 11: event associations -->
                <div data-bind="visible: events().length > 0" class="mb-2">
                    <label class="form-label">Linked events</label>
                    <div class="border rounded p-2" style="max-height:120px;overflow-y:auto;" data-bind="foreach: events">
                        <div class="form-check form-check-sm">
                            <input type="checkbox" class="form-check-input"
                                   data-bind="checked: $root.editPhotoSelectedEventIds, checkedValue: id" />
                            <label class="form-check-label small">
                                <span data-bind="text: (eventTypeLabel || eventType) + (year ? ' (' + year + ')' : '')"></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: saveEditPhoto">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit video -->
<div class="modal fade" id="editVideoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit video</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control" data-bind="value: editVideoTitle" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" data-bind="value: editVideoDescription"></textarea>
                </div>
                <div class="mb-2">
                    <label class="form-label">Tags (comma-separated)</label>
                    <input type="text" class="form-control" data-bind="value: editVideoTagsText" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Folder</label>
                    <select class="form-select" data-bind="options: mediaFolders, value: editVideoFolderId, optionsValue: 'id', optionsText: 'name', optionsCaption: '— No folder —'"></select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: saveEditVideo">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit life event (items 5, 9, 10) -->
<div class="modal fade" id="editEventModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit life event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label">Event type</label>
                    <select class="form-select" data-bind="value: editEventType">
                        <option value="BIRT">Birth</option>
                        <option value="DEAT">Death</option>
                        <option value="BAPM">Baptism</option>
                        <option value="CHR">Christening</option>
                        <option value="CONF">Confirmation</option>
                        <option value="ADOP">Adoption</option>
                        <option value="EMIG">Emigration</option>
                        <option value="IMMI">Immigration</option>
                        <option value="NATU">Naturalization</option>
                        <option value="MARB">Marriage Banns</option>
                        <option value="MARL">Marriage License</option>
                        <option value="BURI">Burial</option>
                        <option value="CREM">Cremation</option>
                        <option value="RESI">Residence</option>
                        <option value="EVEN">Custom Event</option>
                    </select>
                </div>
                <div class="row g-2">
                    <div class="col-4">
                        <label class="form-label">Year</label>
                        <input type="number" class="form-control" data-bind="value: editEventYear" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">Month</label>
                        <select class="form-select" data-bind="options: MONTHS, value: editEventMonth, optionsValue: 'v', optionsText: 'l'"></select>
                    </div>
                    <div class="col-4">
                        <label class="form-label">Day</label>
                        <select class="form-select" data-bind="options: editEventDayOptions, value: editEventDay, optionsText: function(v){ return v == null ? '— Day —' : v; }"></select>
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label">Description</label>
                    <input type="text" class="form-control" data-bind="value: editEventDescription" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Place</label>
                    <p class="text-muted small">Search for an address or click the map. A search result sets the place name and pin together.</p>
                    <div class="position-relative border rounded overflow-hidden" style="background:#e9ecef;">
                        <div class="position-absolute m-2 bg-white rounded shadow-sm p-2" style="width:min(320px, calc(100% - 1rem)); z-index:500;">
                            <input type="search" class="form-control form-control-sm" placeholder="Search address…" autocomplete="off" data-bind="textInput: editEventLocationSearchQuery" />
                            <div class="event-map-search small border-top mt-1 pt-1" data-bind="foreach: editEventLocationSearchResults">
                                <div class="search-hit px-1 py-1" style="cursor:pointer;" data-bind="text: display_name, click: function() { $root.pickEditEventLocationResult($data); }"></div>
                            </div>
                        </div>
                        <div id="editEventMap" class="event-mini-map"></div>
                    </div>
                    <div class="text-muted small mt-1" data-bind="visible: editEventLatitude() != null">
                        <span data-bind="text: editEventPlace() ? editEventPlace() : ''"></span>
                        <span class="ms-1" data-bind="visible: editEventLatitude() != null">·</span>
                        <span data-bind="text: editEventLatitude() != null ? Number(editEventLatitude()).toFixed(5) + ', ' + Number(editEventLongitude()).toFixed(5) : ''"></span>
                        <a href="#" class="ms-2 small" data-bind="click: clearEditEventPlace">Clear</a>
                    </div>
                    <div class="mt-2">
                        <label class="form-label mb-0">Place name (editable)</label>
                        <input type="text" class="form-control" data-bind="value: editEventPlace" placeholder="Filled when you pick a search result; you can edit the text." />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: saveEditEvent">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Copy event modal (item 8) -->
<div class="modal fade" id="copyEventModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Copy event to another person</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Select person</label>
                <select class="form-select" data-bind="options: allPeople, value: copyTargetPersonId, optionsValue: 'id', optionsText: 'fullName', optionsCaption: '— Select person —'"></select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: copyEventToPerson">Copy</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.profilePersonId = @(editPersonId.HasValue ? editPersonId.Value.ToString() : "null");
        window.profileIsAdmin = @(User.IsInRole(Constants.Roles.Administrator) ? "true" : "false");
    </script>
    <environment include="Development">
        <script src="~/lib/leaflet/dist/leaflet.js"></script>
        <script src="~/lib/annotorious/annotorious/dist/annotorious.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/leaflet/dist/leaflet.min.js"></script>
        <script src="~/lib/annotorious/annotorious/dist/annotorious.min.js"></script>
    </environment>
    <script src="~/js/profile.js" asp-append-version="true"></script>
}
