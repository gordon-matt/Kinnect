@{
    ViewData["Title"] = "Family Map";
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/leaflet/dist/leaflet.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/lib/leaflet/dist/leaflet.min.css" />
    </environment>
}

<h4 class="mb-3"><i class="bi bi-geo-alt"></i> Family Map</h4>

<div data-bind="visible: loading" class="text-center py-5">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<div id="familyMap" style="width:100%; height:calc(100vh - 200px); border-radius: 8px;" data-bind="visible: !loading()"></div>

<div data-bind="visible: !loading() && pins().length === 0" class="text-center text-muted py-4">
    <p>No location data available. Family members can add their location in their profile.</p>
</div>

@section Scripts {
    <environment include="Development">
        <script src="~/lib/leaflet/dist/leaflet.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/leaflet/dist/leaflet.min.js"></script>
    </environment>

    <script type="module" src="~/js/map.js" asp-append-version="true"></script>
}