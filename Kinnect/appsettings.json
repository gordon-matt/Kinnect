{
  "Authentication": {
    "Provider": "Identity"
  },
  "FileStorage": {
    "BasePath": "D:\\_Docker\\kinnect"
  },
  "ImageProcessing": {
    "AutoShrinkImages": true,
    "MaxWidth": 1920,
    "MaxHeight": 1080,
    "Quality": 80,
    "ThumbnailWidth": 400,
    "ThumbnailHeight": 400,
    "ThumbnailQuality": 70
  },
  "DocumentProcessing": {
    "AllowedExtensions": ".pdf,.jpg,.jpeg,.png,.gif,.webp",
    "MaxFileSizeBytes": 5242880,
    "AutoShrinkDocuments": true
  },
  "VideoProcessing": {
    "ToolsPath": "",
    "AutoShrinkVideos": true,
    "OutputVideoSize": "Hd720", // Possible values: https://ffmpeg.xabe.net/docs/Xabe.FFmpeg.VideoSize.html
    "Crf": 28,
    "AudioBitrate": 128000
  },
  "SeedAdmin": {
    "Email": "admin@kinnect.local",
    "Password": "Admin@123",
    "FirstName": "Admin",
    "LastName": "User"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
